{
  "name": "@mocha/devtools",
  "version": "0.1.0",
  "description": "Mocha DevTools - Component inspector, property tree, signal graph, thread monitor",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mocha/core": "*",
    "@mocha/shared": "*"
  }
}
